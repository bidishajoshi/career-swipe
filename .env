# CareerSwipe Environment Variables

SECRET_KEY=careerswipe-dev-secret-2026

# DATABASE CONFIGURATION (Supabase)
# ---------------------------------
# 1. Sign up at supabase.com
# 2. Get your "Connection String" (URI) from Settings > Database
# 3. Paste it below and replace [YOUR-PASSWORD] with your actual password.
# 
# IMPORTANT: If your password has special characters, ensure the URI is correct.
# DATABASE_URL=postgresql://postgres.[PROJECT-ID]:%23Careerswipe1@aws-0-[REGION].pooler.supabase.com:6543/postgres

# GMAIL SMTP CONFIGURATION
# ------------------------
# Use an App Password (not your real Gmail password)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# CareerSwipe Environment Variables
# Copy this file to .env and fill in your values

SECRET_KEY=your-very-secret-key-change-this-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# For local development (SQLite — no setup needed):
# DATABASE_URL=sqlite:///careerswipe.db

# For PostgreSQL (local or Render):
# DATABASE_URL=postgresql://username:password@localhost:5432/careerswipe

# On Render: set DATABASE_URL in Environment Variables panel
# Render provides: postgres://... — the app auto-converts it to postgresql://
DATABASE_URL=sqlite:///careerswipe.db

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Create a Gmail App Password: https://support.google.com/accounts/answer/185833
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_gmail_app_password

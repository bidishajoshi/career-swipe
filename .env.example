# ════════════════════════════════════════════════════════════════════════════
# CareerSwipe Environment Configuration
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values

# ── Flask Application ──────────────────────────────────────────────────────
FLASK_ENV=production                    # development, production, or testing
SECRET_KEY=your-super-secret-key-here   # Change in production!
DEBUG=False                             # Set to False in production

# ── Database (PostgreSQL on Render or Local) ──────────────────────────────
# For Render: Use the Internal Connection URL from your PostgreSQL database
# Format: postgresql://username:password@host:5432/dbname

# Local Development with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/careerswipe

# Local Development with SQLite (default if DATABASE_URL not set):
# DATABASE_URL=sqlite:///careerswipe.db

DATABASE_URL=postgresql://user:password@dpg-xxxxx.postgres.render.com:5432/careerswipe_db

# ── Email Configuration (Gmail SMTP) ───────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password  # Use Gmail App Password, not regular password

# ── Server Configuration ───────────────────────────────────────────────────
PORT=5000                               # For Render, leave as 5000 (auto-detected)

# ── Optional: Analytics, Logging, etc. ────────────────────────────────────
# Add any other environment variables your application needs here
